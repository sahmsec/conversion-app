// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// One settings row per widget per shop. `enabled`, `type`, and `shop` are columns
/// (queried by the dashboard + storefront sync); all visual/behavioral config lives
/// in the `config` JSON so new widgets never require a schema migration.
model WidgetSettings {
  id        String     @id @default(cuid())
  shop      String
  type      WidgetType
  enabled   Boolean    @default(false)
  config    Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([shop, type])
  @@index([shop])
}

enum WidgetType {
  STICKY_ATC
  ANNOUNCEMENT_BAR
  FREE_SHIPPING_BAR
  TRUST_BADGES
  CART_GOAL
  COUNTDOWN
  SALES_POP
}

/// Rolling recent orders for the Sales Pop widget (real social proof). Populated by
/// the orders/create webhook; the storefront reads the latest few via App Proxy.
model RecentSale {
  id        String   @id @default(cuid())
  shop      String
  product   String
  city      String?
  region    String?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
}

/// Aggregated per-day widget analytics (impressions / clicks / goals). One row per
/// shop + widget + event + day, incremented as batched events arrive.
model WidgetStat {
  id        String   @id @default(cuid())
  shop      String
  widget    String // storefront key, e.g. "sticky-cart"
  event     String // "impression" | "click" | "goal"
  day       String // UTC date, "YYYY-MM-DD"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([shop, widget, event, day])
  @@index([shop])
}
