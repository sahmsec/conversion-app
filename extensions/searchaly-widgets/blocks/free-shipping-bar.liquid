{%- comment -%}
  Free Shipping Bar — placement block. Drop it where you want the bar to appear; it
  renders inline here using your Conversion App dashboard settings. Requires the
  Conversion App embed to be enabled (Theme settings → App embeds).
{%- endcomment -%}
<div data-searchaly-slot="free-shipping-bar" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Free Shipping Bar",
  "target": "section",
  "stylesheet": "searchaly.css",
  "settings": [
    { "type": "paragraph", "content": "Set this widget's message, goal and colors in the Conversion App dashboard. Make sure the Conversion App embed is on (Theme settings → App embeds)." }
  ]
}
{% endschema %}
