{%- comment -%}
  Announcement Bar — placement block. Drop it where you want the announcement to
  appear; it renders inline here using your Conversion App dashboard settings.
  Requires the Conversion App embed to be enabled (Theme settings → App embeds).
{%- endcomment -%}
<div data-searchaly-slot="announcement-bar" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Announcement Bar",
  "target": "section",
  "stylesheet": "searchaly.css",
  "settings": [
    { "type": "paragraph", "content": "Set this widget's messages, rotation and colors in the Conversion App dashboard. Make sure the Conversion App embed is on (Theme settings → App embeds)." }
  ]
}
{% endschema %}
