{%- comment -%}
  Cart Goal — placement block. Drop it where you want the goal bar to appear; it
  renders inline here using your Conversion App dashboard settings. Requires the
  Conversion App embed to be enabled (Theme settings → App embeds).
{%- endcomment -%}
<div data-searchaly-slot="cart-goal" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Cart Goal",
  "target": "section",
  "stylesheet": "searchaly.css",
  "settings": [
    { "type": "paragraph", "content": "Set this widget's message, goal and reward in the Conversion App dashboard. Make sure the Conversion App embed is on (Theme settings → App embeds)." }
  ]
}
{% endschema %}
