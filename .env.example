# Postgres connection string (Neon free tier recommended).
# Neon: create a project at https://neon.tech, copy the "Prisma"/pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# The following are injected automatically by `shopify app dev`. Only set them
# manually for a hosted deployment (Render/Fly/etc.):
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=
# SCOPES=
